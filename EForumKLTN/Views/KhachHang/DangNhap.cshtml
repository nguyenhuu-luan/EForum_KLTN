@model EForumKLTN.ViewModels.LoginVM
@{
    ViewData["Title"] = "Đăng nhập - E-Forum";
}

<div class="container-fluid py-5 bg-light" style="min-height: 80vh;">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 p-sm-5">
                        <div class="text-center mb-4">
                            <h2 class="fw-bold text-primary">Đăng Nhập</h2>
                            <p class="text-muted">Chào mừng bạn quay lại với E-Forum</p>
                        </div>

                        <form asp-action="DangNhap" method="post" asp-route-returnurl="@ViewBag.ReturnUrl">
                            <div class="text-danger mb-3" asp-validation-summary="All"></div>

                            <div class="form-floating mb-3">
                                <input asp-for="UserName" class="form-control" placeholder="Tên đăng nhập" style="border-radius: 10px;">
                                <label asp-for="UserName">Tên đăng nhập</label>
                                <span asp-validation-for="UserName" class="text-danger small"></span>
                            </div>

                            <div class="form-floating mb-3">
                                <input asp-for="Password" type="password" class="form-control" placeholder="Mật khẩu" style="border-radius: 10px;">
                                <label asp-for="Password">Mật khẩu</label>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="text-end mb-4">
                                <a asp-controller="KhachHang" asp-for="QuenMatKhau" class="text-decoration-none small text-muted">Quên mật khẩu?</a>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 py-3 mb-4 fw-bold text-uppercase" style="border-radius: 10px; letter-spacing: 1px;">
                                Đăng nhập
                            </button>

                            <div class="position-relative my-4">
                                <hr class="text-muted">
                                <span class="position-absolute top-50 start-50 translate-middle bg-white px-2 text-muted small">hoặc</span>
                            </div>

                            <div class="row g-2 mb-4">
                                <div class="col-6">
                                    <a href="/KhachHang/ExternalLogin?provider=Google" class="btn btn-outline-danger w-100 py-2 d-flex align-items-center justify-content-center" style="border-radius: 10px; font-size: 0.9rem;">
                                        <i class="fab fa-google me-2"></i> Google
                                    </a>
                                </div>
                                <div class="col-6">
                                    <a href="/KhachHang/ExternalLogin?provider=Facebook"
                                           class="btn btn-outline-primary w-100 py-2 d-flex align-items-center justify-content-center"
                                           style="border-radius: 10px; font-size: 0.9rem; font-weight: 600; border-color: #1877F2; color: #1877F2;">
                                        <i class="fab fa-facebook-f me-2"></i> Facebook
                                    </a>
                                </div>
                            </div>
                         

                            <div class="text-center mt-4 pb-2">
                                <p class="mb-0 small text-muted">
                                    Chưa có tài khoản?
                                    <a asp-controller="KhachHang" asp-action="DangKy" class="text-primary fw-bold text-decoration-none">
                                        Tạo tài khoản
                                    </a>
                                </p>
                            </div>
                        </form>
                    </div>
                </div>
                
                <div class="text-center mt-4">
                    <a href="/" class="text-muted text-decoration-none small">
                        <i class="bi bi-arrow-left"></i> Quay lại trang chủ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>