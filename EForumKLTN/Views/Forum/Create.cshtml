@model EForumKLTN.Models.BaiViet

@{
    ViewData["Title"] = "Đăng bài mới";
}

<div class="container-fluid py-5">
    <div class="container py-5">
        <div class="mx-auto" style="max-width: 800px;">
            <h1 class="display-5 mb-4 text-primary">Chia sẻ bài viết mới</h1>
            
            <form asp-action="Create" method="post" class="p-5 bg-light rounded border border-primary shadow">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="form-group mb-4">
                    <label class="form-label fw-bold">Chủ đề thảo luận</label>
                    <select asp-for="MaCd" class="form-select border-primary p-3"
                            asp-items="@(new SelectList(ViewBag.ChuDes, "MaCd", "TenChuDe", ViewBag.MaCd))">
                    </select>
                </div>

                <div class="form-group mb-4">
                    <label class="form-label fw-bold">Tiêu đề bài viết</label>
                    <input asp-for="TieuDe" class="form-control border-primary p-3" placeholder="Nhập tiêu đề ngắn gọn, xúc tích..." />
                    <span asp-validation-for="TieuDe" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label class="form-label fw-bold">Nội dung chi tiết</label>
                    <textarea asp-for="NoiDung" class="form-control border-primary p-3" rows="8" placeholder="Viết nội dung thảo luận ở đây..."></textarea>
                    <span asp-validation-for="NoiDung" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="text-secondary"><i class="fas fa-arrow-left me-2"></i>Quay lại</a>
                    <button type="submit" class="btn btn-primary border-2 border-primary rounded-pill py-3 px-5 text-white">
                        <i class="fas fa-paper-plane me-2"></i>Đăng bài ngay
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>