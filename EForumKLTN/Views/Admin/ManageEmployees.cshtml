@model IEnumerable<EForumKLTN.Models.KhachHang>

<div class="container-fluid pt-4 px-4">
    <div class="bg-light rounded p-4 shadow-sm">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-dark">
                <i class="fas fa-user-tie me-2 text-warning"></i>
                Quản lý nhân viên
            </h2>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã NV</th>
                        <th>Họ tên</th>
                        <th>Điện thoại</th>
                        <th>Coupon</th>
                        <th>KPI</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        var coupon = item.Coupons.FirstOrDefault();

                        <tr>
                            <td class="fw-bold text-primary">
                                #@item.MaKh
                            </td>

                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="/Hinh/KhachHang/@item.Hinh"
                                         class="rounded-circle me-2"
                                         style="width:40px;height:40px;" />

                                    <span>@item.HoTen</span>
                                </div>
                            </td>

                            <td>@item.DienThoai</td>

                            <td>
                                @if (coupon != null)
                                {
                                    <span class="badge bg-success">
                                        @coupon.MaCoupon
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        Chưa có mã
                                    </span>
                                }
                            </td>

                            <td>
                                <span class="badge bg-warning text-dark">
                                    @item.KPI KPI
                                </span>
                            </td>

                            <td class="text-center">
                                @if (coupon == null)
                                {
                                    <a asp-action="GenerateCoupon"
                                           asp-route-id="@item.MaKh"
                                           class="btn btn-sm btn-success rounded-pill px-3">
                                        <i class="fas fa-key me-1"></i>
                                        Tạo mã
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-secondary rounded-pill px-3" disabled>
                                        Đã có mã
                                    </button>
                                }
                            </td>

                        </tr>
                    }
                </tbody>

            </table>
        </div>

    </div>
</div>