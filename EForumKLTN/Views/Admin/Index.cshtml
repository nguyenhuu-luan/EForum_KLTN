@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid pt-4 px-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="mb-0 text-dark fw-bold">
            <i class="fas fa-chart-line me-2 text-primary"></i>Hệ Thống Quản Trị
        </h2>
        <span class="text-secondary small fw-medium text-orange-bold">Chào mừng quay trở lại, Admin!</span>
    </div>

    <div class="row g-4">
        <div class="col-sm-6 col-xl-4">
            <div class="bg-light rounded d-flex align-items-center justify-content-between p-4 shadow-sm border-start border-primary border-5">
                <div class="icon-box bg-soft-primary p-3 rounded-circle">
                    <i class="fa fa-users fa-2x text-primary"></i>
                </div>
                <div class="ms-3 text-end">
                    <p class="mb-2 text-secondary fw-bold text-orange-bold">Người dùng</p>
                    <h3 class="mb-0 fw-bold">@ViewBag.TotalUsers</h3>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-4">
            <div class="bg-light rounded d-flex align-items-center justify-content-between p-4 shadow-sm border-start border-success border-5">
                <div class="icon-box bg-soft-success p-3 rounded-circle">
                    <i class="fa fa-newspaper fa-2x text-success"></i>
                </div>
                <div class="ms-3 text-end">
                    <p class="mb-2 text-secondary fw-bold text-orange-bold">Bài viết Forum</p>
                    <h3 class="mb-0 fw-bold">@ViewBag.TotalPosts</h3>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-4">
            <div class="bg-light rounded d-flex align-items-center justify-content-between p-4 shadow-sm border-start border-warning border-5">
                <div class="icon-box bg-soft-warning p-3 rounded-circle">
                    <i class="fa fa-book fa-2x text-warning"></i>
                </div>
                <div class="ms-3 text-end">
                    <p class="mb-2 text-secondary fw-bold text-orange-bold">Sách/Ebook</p>
                    <h3 class="mb-0 fw-bold">@ViewBag.TotalEbooks</h3>
                </div>
            </div>
        </div>
    </div>
    
    <div class="mt-5">
        <h4 class="mb-4 fw-bold text-dark">Chức năng quản trị</h4>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4 col-xl-3">
                <a asp-controller="Admin" asp-action="ManageUsers" class="admin-nav-card">
                    <i class="fas fa-users-cog"></i>
                    <span>Quản lý người dùng</span>
                </a>
            </div>
            <div class="col-md-6 col-lg-4 col-xl-3">
                <a href="/Admin/ManageStaff" class="admin-nav-card">
                    <i class="fas fa-user-tie"></i>
                    <span>Quản lý nhân viên</span>
                </a>
            </div>
            <div class="col-md-6 col-lg-4 col-xl-3">
                <a href="/Admin/ManageOrders" class="admin-nav-card">
                    <i class="fas fa-shopping-cart"></i>
                    <span>Quản lý đơn hàng</span>
                </a>
            </div>
            <div class="col-md-6 col-lg-4 col-xl-3">
                <a asp-controller="Admin" asp-action="ManagePosts" class="admin-nav-card">
                    <i class="fas fa-edit"></i>
                    <span>Quản lý bài viết</span>
                </a>
            </div>
            <div class="col-md-6 col-lg-4 col-xl-3">
                <a href="/Admin/ManageProducts" class="admin-nav-card">
                    <i class="fas fa-boxes"></i>
                    <span>Quản lý kho sách</span>
                </a>
            </div>
            <div class="col-md-6 col-lg-4 col-xl-3">
                <a href="/Admin/Settings" class="admin-nav-card accent-gray">
                    <i class="fas fa-cogs"></i>
                    <span>Cấu hình hệ thống</span>
                </a>
            </div>
        </div>
    </div>

    <div class="mt-5">
        <a asp-controller="KhachHang" asp-action="DangXuat" class="btn btn-outline-danger px-5 rounded-pill shadow-sm d-inline-flex align-items-center">
            <i class="fas fa-sign-out-alt me-2"></i> Đăng xuất hệ thống
        </a>
    </div>
</div>

<style>
    /* Stats Icons Backgrounds */
    .bg-soft-primary { background-color: rgba(0, 123, 255, 0.1); }
    .bg-soft-success { background-color: rgba(40, 167, 69, 0.1); }
    .bg-soft-warning { background-color: rgba(255, 193, 7, 0.1); }

    /* Admin Navigation Cards */
    .admin-nav-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
        background: #fff;
        border-radius: 15px;
        text-decoration: none;
        color: #333;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
        border: 1px solid transparent;
        height: 100%;
    }

    .admin-nav-card i {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        color: #007bff;
    }

    .admin-nav-card span {
        font-weight: 600;
        text-align: center;
    }

    .admin-nav-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        border-color: #007bff;
        color: #007bff;
    }

    .admin-nav-card.accent-gray i { color: #6c757d; }
    .admin-nav-card.accent-gray:hover { border-color: #6c757d; color: #6c757d; }
    .text-orange-bold {
        color: #e65100 !important;
        font-weight: 700;
    }
</style>