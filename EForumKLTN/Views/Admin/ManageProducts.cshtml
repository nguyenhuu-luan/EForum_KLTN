@model IEnumerable<EForumKLTN.ViewModels.HangHoaVM>

<div class="container-fluid pt-4 px-4">
    <div class="bg-light text-center rounded p-4 shadow-sm">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h2 class="mb-0 text-dark fw-bold">
                <i class="fas fa-boxes me-2 text-primary"></i>Quản lý kho sách
            </h2>
            <a asp-action="CreateProduct" class="btn btn-primary rounded-pill px-4">
                <i class="fas fa-plus-circle me-2"></i>Thêm sách mới
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
                <i class="fa fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="table-responsive">
            <table class="table text-start align-middle table-hover mb-0">
                <thead class="bg-white text-dark shadow-sm">
                    <tr class="text-dark">
                        <th scope="col" class="py-3">Mã HH</th>
                        <th scope="col" class="py-3">Hình</th>
                        <th scope="col" class="py-3" style="width: 30%;">Tên sản phẩm</th>
                        <th scope="col" class="py-3">Loại</th>
                        <th scope="col" class="py-3">Giá bán</th>
                        <th scope="col" class="py-3 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-primary">#@item.MaHH</td>
                            <td>
                                <img src="/Hinh/SanPham/@item.Hinh" class="rounded border" style="width: 50px; height: 50px; object-fit: cover;" onerror="this.src='/Hinh/SanPham/default.png'">
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.TenHH</div>
                                <small class="text-secondary text-truncate d-inline-block" style="max-width: 200px;">@item.MoTaNgan</small>
                            </td>
                            <td>
                                <span class="badge bg-soft-info text-info-dark border border-info-dark px-2">@item.TenLoai</span>
                            </td>
                            <td>
                                <span class="text-orange-bold">@item.DonGia.ToString("#,##0") đ</span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="EditProduct" asp-route-id="@item.MaHH" 
                                       class="btn btn-sm btn-warning text-white px-3 rounded-pill shadow-sm">
                                        <i class="fas fa-edit me-1"></i> Sửa
                                    </a>
                                    <a asp-action="DeleteProduct" asp-route-id="@item.MaHH" 
                                       class="btn btn-sm btn-danger px-3 rounded-pill shadow-sm" 
                                       onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')">
                                        <i class="fas fa-trash-alt me-1"></i> Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Dùng lại các class màu cam đậm bạn đã chọn */
    .text-orange-bold { color: #e65100 !important; font-weight: 700; }
    .bg-soft-info { background-color: #e1f5fe !important; }
    .text-info-dark { color: #0288d1 !important; }
    .border-info-dark { border-color: #b3e5fc !important; }
</style>