@model IEnumerable<EForumKLTN.Models.BaiViet>

<div class="container-fluid pt-4 px-4">
    <div class="bg-light text-center rounded p-4 shadow-sm">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h2 class="mb-0 text-dark fw-bold">
                <i class="fas fa-file-alt me-2 text-primary"></i>Quản lý bài viết
            </h2>
            <a asp-action="CreatePost" class="btn btn-primary rounded-pill px-4">
                <i class="fas fa-plus-circle me-2"></i>Viết bài mới
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
                <i class="fa fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="table-responsive">
            <table class="table text-start align-middle table-hover mb-0">
                <thead class="bg-white text-dark shadow-sm">
                    <tr class="text-dark">
                        <th scope="col" class="py-3">Mã BV</th>
                        <th scope="col" class="py-3" style="width: 40%;">Tiêu đề</th>
                        <th scope="col" class="py-3 text-center">Người đăng</th>
                        <th scope="col" class="py-3 text-center">Ngày đăng</th>
                        <th scope="col" class="py-3 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-primary">#@item.MaBv</td>
                            <td>
                                <div class="text-truncate" style="max-width: 350px;" title="@item.TieuDe">
                                    <a href="#" class="text-dark fw-bold">@item.TieuDe</a>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-soft-info text-info-dark border border-info px-2">
                                    <i class="fas fa-user-edit me-1"></i> ID: @item.MaKh
                                </span>
                            </td>
                            <td class="text-center text-secondary small" style="color: #e65100 !important">
                                @item.NgayDang
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="EditPost" asp-route-id="@item.MaBv"
                                           class="btn btn-sm btn-warning text-white px-3 rounded-pill shadow-sm">
                                        <i class="fas fa-edit me-1"></i> Sửa
                                    </a>
                                    <a asp-action="DeletePost" asp-route-id="@item.MaBv"
                                           class="btn btn-sm btn-danger px-3 rounded-pill shadow-sm"
                                           onclick="return confirm('Bạn có chắc chắn muốn xóa bài viết này?')">
                                        <i class="fas fa-trash-alt me-1"></i> Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-soft-info {
        background-color: #e0f2f1 !important;
    }
    .text-info-dark {
        color: #0288d1 !important;
    }
    
    .table-hover tbody tr:hover {
        background-color: rgba(0, 0, 0, 0.03);
        transition: all 0.2s ease;
    }

    .text-truncate {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
</style>