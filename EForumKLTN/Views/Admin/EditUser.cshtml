@model EForumKLTN.ViewModels.EditUserVM

<div class="container-fluid pt-4 px-4">
    <div class="row justify-content-center">
        <div class="col-sm-12 col-xl-6">
            <div class="bg-light rounded h-100 p-4 shadow-sm">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h2 class="mb-0 text-dark fw-bold">
                        <i class="fas fa-user-edit me-2 text-primary"></i>Cập nhật người dùng
                    </h2>
                    <a asp-controller="Admin" asp-action="ManageUsers" class="btn btn-outline-secondary btn-sm rounded-pill">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại
                    </a>
                </div>

                <form asp-action="EditUser" method="post">
                    @* Input ẩn nếu cần thiết cho Model Binding *@
                    <input type="hidden" asp-for="MaKh" />

                    <div class="form-floating mb-3">
                        <input asp-for="MaKh" class="form-control bg-white" readonly placeholder="Mã khách hàng" />
                        <label asp-for="MaKh">Mã khách hàng (ID)</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="HoTen" class="form-control" placeholder="Họ và tên" />
                        <label asp-for="HoTen">Họ và tên</label>
                        <span asp-validation-for="HoTen" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="DienThoai" class="form-control" placeholder="Số điện thoại" />
                        <label asp-for="DienThoai">Số điện thoại</label>
                        <span asp-validation-for="DienThoai" class="text-danger small"></span>
                    </div>

                    <div class="mb-3 d-flex align-items-center p-3 border rounded bg-white">
                        <div class="form-check form-switch">
                            <input asp-for="IsAdmin" class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
                            <label class="form-check-label fw-bold ms-2" for="flexSwitchCheckDefault">
                                Quyền quản trị (Admin)
                            </label>
                        </div>
                    </div>

                    <div class="d-grid gap-2 pt-3">
                        <button type="submit" class="btn btn-primary py-3 rounded-pill fw-bold shadow-sm">
                            <i class="fas fa-save me-2"></i> Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    /* Làm mờ nhẹ input readonly để người dùng biết không sửa được */
    input[readonly] {
        background-color: #e9ecef !important;
        opacity: 0.8;
        cursor: not-allowed;
    }

    /* Hiệu ứng focus cho input */
    .form-control:focus {
        border-color: #007bff;
        box-shadow: 0 0 0 0.25rem rgba(0, 123, 255, 0.1);
    }
    
    /* Chỉnh màu cho Switch khi được chọn */
    .form-check-input:checked {
        background-color: #0d6efd;
        border-color: #0d6efd;
    }
</style>