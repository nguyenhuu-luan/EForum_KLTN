@model EForumKLTN.ViewModels.HangHoaVM

<div class="vesitable-item m-2">
    <div class="rounded position-relative fruite-item">

        <div class="fruite-img-homeindex">
            <a asp-action="Detail" asp-controller="HangHoa" asp-route-id="@Model.MaHH">
                <img src="~/Hinh/SanPham/@Model.Hinh"
                     class="img-fluid-homeindex w-100 rounded-top"  
                     alt="@Model.TenHH">
            </a>
        </div>

        <div class="text-white bg-secondary px-3 py-1 rounded position-absolute"
             style="top: 10px; left: 10px;">
            @Model.TenLoai
        </div>

        <div class="p-4 border border-secondary border-top-0 rounded-bottom">
            <a asp-action="Detail" asp-controller="HangHoa" asp-route-id="@Model.MaHH">
                <h4 class="product-title">@Model.TenHH</h4>
            </a>
            <p class="product-desc">@Model.MoTaNgan</p>
            <div class="d-flex justify-content-between flex-lg-wrap">
                <p class="text-dark fs-5 fw-bold mb-0">
                    @Model.DonGia.ToString("#,##0") đ
                </p>
                <a asp-action="AddToCart" asp-controller="Cart" asp-route-id="@Model.MaHH"
                   class="btn border border-secondary rounded-pill px-3 text-primary">
                    <i class="fa fa-shopping-bag me-2 text-primary"></i>
                    Add to cart
                </a>
            </div>
        </div>
    </div>
</div>