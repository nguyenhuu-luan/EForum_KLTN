@model IEnumerable<EForumKLTN.ViewModels.MenuLoaiVM>


<div class="col-lg-12">
    <div class="mb-3">
        <h4>Danh mục sách</h4>
        <ul class="list-unstyled fruite-categorie">
            @foreach (var item in Model)
            {
                <li>
                    <div class="d-flex justify-content-between fruite-name">                        
                        <a asp-controller="HangHoa" asp-action="Index" asp-route-loai="@item.MaLoai" class="text-dark">
                            <i class="fas fa-book me-2 text-primary"></i>@item.TenLoai
                        </a>
                        <span class="text-orange-bold">(@item.SoLuong)</span>
                    </div>
                </li>
            }

        </ul>
    </div>
</div>
