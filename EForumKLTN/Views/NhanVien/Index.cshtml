@model IEnumerable<EForumKLTN.Models.HoaDon>

<div class="container-fluid pt-4 px-4">
    <div class="bg-light rounded p-4 shadow-sm">

        <h2 class="mb-4">
            Quản lý đơn hàng
        </h2>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }

        <table class="table table-hover">

            <thead>
                <tr>
                    <th>Mã HD</th>
                    <th>Khách hàng</th>
                    <th>Ngày đặt</th>
                    <th>Mã giới thiệu</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.MaHd</td>

                        <td>
                            @item.MaKhNavigation.HoTen
                        </td>

                        <td>
                            @item.NgayDat
                        </td>

                        <td>
                            @if (!string.IsNullOrEmpty(item.MaKH_NV))
                            {
                                <span class="badge bg-info text-dark">
                                    @item.MaKH_NV
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">
                                    Không có
                                </span>
                            }
                        </td>

                        <td>
                            @item.TongTien VNĐ
                        </td>

                        <td>

                            @if (item.MaTrangThai == 0)
                            {
                                <span class="badge bg-warning">
                                    Chờ thanh toán
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">
                                    Đã thanh toán
                                </span>
                            }

                        </td>

                        <td>

                            @if (item.MaTrangThai == 0)
                            {
                                <a asp-action="XacNhanThanhToan"
                                       asp-route-id="@item.MaHd"
                                       class="btn btn-success btn-sm">

                                    Xác nhận
                                </a>
                            }

                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>
</div>