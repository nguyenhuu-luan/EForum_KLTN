@model EForumKLTN.ViewModels.HomeVM

@{
    ViewData["Title"] = "Trang chủ E-Forum";
}

<div class="container-fluid py-5">
    <div class="container py-5">
        <h2 class="display-6 text-primary mb-4">Thảo luận mới nhất</h2>
        <div class="row g-4">
            @foreach (var bv in Model.TopPosts)
            {
                <div class="col-lg-4">
                    <div class="p-4 rounded bg-light border border-primary shadow-sm h-100">
                        <a asp-action="Details" asp-controller="Forum" asp-route-id="@bv.MaBv" class="h4 text-dark text-decoration-none">@bv.TieuDe</a>
                        <p class="text-muted mt-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @bv.NoiDung
                        </p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <small><i class="fas fa-user text-primary me-2"></i>@bv.MaKhNavigation?.HoTen</small>
                            <small class="text-secondary">@bv.NgayDang?.ToString("dd/MM/yyyy")</small>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="container-fluid vesitable py-5">
    <div class="container py-5">
        <h2 class="display-6 text-primary mb-4">Sản phẩm Ebook nổi bật</h2>
        <div class="owl-carousel vegetable-carousel justify-content-center">
            @foreach (var hh in Model.FeaturedProducts)
            {
                <div class="border border-primary rounded position-relative vesitable-item m-2">
                    <div class="vesitable-img">
                        <img src="~/Hinh/HangHoas/@hh.Hinh" class="img-fluid w-100 rounded-top" alt="@hh.TenHh">
                    </div>
                    <div class="p-4 rounded-bottom">
                        <h4 style="font-size: 1.1rem; height: 50px; overflow: hidden;">@hh.TenHh</h4>
                        <div class="d-flex justify-content-between flex-lg-wrap">
                            <p class="text-dark fs-5 fw-bold mb-0">@hh.DonGia?.ToString("#,##0") đ</p>
                            <a href="#" class="btn border border-secondary rounded-pill px-3 text-primary">
                                <i class="fa fa-shopping-bag me-2 text-primary"></i> Mua
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>