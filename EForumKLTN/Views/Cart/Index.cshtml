@model IEnumerable<EForumKLTN.ViewModels.CartItem> 
@{
    ViewData["Title"] = "Giỏ hàng";
}

<!-- Single Page Header start -->
<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Giỏ hàng</h1>
    <ol class="breadcrumb justify-content-center mb-0">
        <li class="breadcrumb-item"><a href="#">Trang chủ</a></li>
        <li class="breadcrumb-item active text-white">Giỏ hàng</li>
    </ol>
</div>
<!-- Single Page Header End -->
<!-- Cart Page Start -->
<div class="container-fluid py-5">
    <div class="container py-5">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th scope="col">Hình mô tả</th>
                        <th scope="col">Tên sản phẩm</th>
                        <th scope="col">Giá</th>
                        <th scope="col">Số lượng</th>
                        <th scope="col">Tổng tiền</th>
                        <th scope="col"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <th scope="row">
                                <div class="d-flex align-items-center">
                                    <img src="~/Hinh/SanPham/@item.Hinh" class="img-fluid me-5 " style="width: 80px; height: 80px;" alt="@item.TenHH">
                                </div>
                            </th>
                            <td>
                                <p class="mb-0 mt-4">
                                    <a asp-action="Detail" asp-controller="HangHoa" asp-route-id="@item.MaHH">
                                        @item.TenHH
                                    </a>
                                </p>
                            </td>
                            <td>
                                <p class="mb-0 mt-4">$ @item.DonGia</p>
                            </td>
                            <td>
                                <div class="input-group quantity mt-4 border rounded-pill" style="width: 100px;">
                                    <div class="input-group-btn">
                                        <button class="btn btn-sm btn-minus rounded-circle bg-light border">
                                            <i class="fa fa-minus"></i>
                                        </button>
                                    </div>
                                    <input type="text" class="form-control form-control-sm text-center border-0" value="@item.SoLuong">
                                    <div class="input-group-btn">
                                        <button class="btn btn-sm btn-plus rounded-circle bg-light border">
                                            <i class="fa fa-plus"></i>
                                        </button>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <p class="mb-0 mt-4">$ @item.ThanhTien</p>
                            </td>
                            <td>
                                <a asp-action="RemoveCart" asp-controller="Cart" asp-route-id="@item.MaHH" class="btn btn-md rounded-circle bg-light border mt-4">
                                    <i class="fa fa-times text-danger"></i>
                                </a>
                            </td>

                        </tr>                                
                    }
                </tbody>
            </table>
        </div>

        <form asp-controller="Cart"
              asp-action="ThanhToan"
              method="post">

            <!-- Coupon -->
            <div class="mt-5">
                <input type="text"
                       name="couponCode"
                       class="border-0 border-bottom rounded me-3 py-3 mb-4"
                       placeholder="Mã giới thiệu">
            </div>

            <!-- Hóa đơn -->
            <div class="py-4 mb-4 border-top border-bottom d-flex justify-content-between">
                <h5 class="mb-0 ps-4 me-4">Tổng cộng</h5>
                <p class="mb-0 pe-4">$@Model.Sum(p => p.ThanhTien)</p>
            </div>

            <!-- CHỈ 1 NÚT -->
            <button type="submit"
                    class="btn border-secondary rounded-pill px-4 py-3 text-primary text-uppercase mb-4 ms-4">

                Xác nhận thanh toán
            </button>

        </form>

    </div>
</div>
<!-- Cart Page End -->
