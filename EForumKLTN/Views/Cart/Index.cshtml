@model IEnumerable<EForumKLTN.ViewModels.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng";
    var total = Model.Sum(p => p.ThanhTien);
}

<div class="container-fluid py-5">
    <div class="container py-5">

        <!-- HEADER -->
        <div class="mb-4">
            <h2 class="fw-bold">Giỏ hàng</h2>
            <p class="text-muted">Kiểm tra lại sản phẩm trước khi thanh toán</p>
        </div>

        <!-- TABLE -->
        <div class="table-responsive mb-4">
            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Hình</th>
                        <th>Sản phẩm</th>
                        <th>Giá</th>
                        <th>Số lượng</th>
                        <th>Tổng</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <img src="~/Hinh/SanPham/@item.Hinh"
                                     style="width:70px;height:70px;border-radius:8px;" />
                            </td>

                            <td class="fw-semibold">
                                <a asp-action="Detail"
                                       asp-controller="HangHoa"
                                       asp-route-id="@item.MaHH">
                                    @item.TenHH
                                </a>
                            </td>

                            <td>@item.DonGia</td>
                            <td>@item.SoLuong</td>
                            <td class="fw-bold">@item.ThanhTien</td>

                            <td>
                                <a asp-action="RemoveCart"
                                       asp-route-id="@item.MaHH"
                                       class="btn btn-sm btn-outline-danger">
                                    Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

        <!-- CHECKOUT BOX -->
        <form asp-controller="Cart"
              asp-action="ThanhToan"
              method="post">

            <div class="row">

                <!-- LEFT: COUPON -->
                <div class="col-md-7">

                    <div class="card border-0 shadow-sm p-4">

                        <h5 class="mb-3">Mã giảm giá nhân viên</h5>

                        <input type="text"
                               id="couponInput"
                               name="couponCode"
                               class="form-control mb-3"
                               placeholder="Nhập mã..." />

                        <small class="text-muted">
                            Nhập mã để nhận ưu đãi (nếu có)
                        </small>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <span>Giảm giá:</span>
                            <strong id="discount">0 đ</strong>
                        </div>

                        <div class="d-flex justify-content-between mt-2">
                            <span>Tổng sau giảm:</span>
                            <strong id="finalTotal">@total</strong>
                        </div>

                    </div>
                </div>

                <!-- RIGHT: SUMMARY -->
                <div class="col-md-5">

                    <div class="card border-0 shadow-sm p-4">

                        <h5 class="mb-3">Tổng thanh toán</h5>

                        <div class="d-flex justify-content-between">
                            <span>Tạm tính:</span>
                            <strong>@total</strong>
                        </div>

                        <div class="d-flex justify-content-between mt-2">
                            <span>Giảm giá:</span>
                            <strong id="discount2">0</strong>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between fs-5">
                            <span>Tổng cộng:</span>
                            <strong id="finalTotal2">@total</strong>
                        </div>

                        <button type="submit"
                                class="btn btn-primary w-100 mt-3">

                            Xác nhận thanh toán
                        </button>

                    </div>
                </div>

            </div>

        </form>

    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    var baseTotal = @total;

    $("#couponInput").on("input", function () {

        var code = $(this).val();

        if (code.length === 0) {
            $("#discount, #discount2").text(0);
            $("#finalTotal, #finalTotal2").text(baseTotal);
            return;
        }

        $.get("/Cart/CheckCoupon", { code: code }, function (res) {

            if (!res.valid) {
                $("#discount, #discount2").text("0");
                $("#finalTotal, #finalTotal2").text(res.total);
            } else {
                $("#discount, #discount2").text(res.discount.toFixed(0));
                $("#finalTotal, #finalTotal2").text(res.finalTotal.toFixed(0));
            }
        });

    });
</script>